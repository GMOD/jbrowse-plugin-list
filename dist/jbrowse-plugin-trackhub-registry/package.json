{
  "version": "2.0.0",
  "name": "jbrowse-plugin-trackhub-registry",
  "keywords": [
    "jbrowse",
    "jbrowse2"
  ],
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "format": "prettier --write .",
    "prebuild": "yarn clean",
    "start": "node esbuild.mjs --watch",
    "build": "tsc && NODE_ENV=production node esbuild.mjs",
    "postbuild": "cp distconfig.json dist/config.json",
    "lint": "eslint --ext .js,.ts,.jsx,.tsx src/",
    "prepack": "yarn build",
    "postversion": "git push --follow-tags"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "trailingComma": "all"
  },
  "dependencies": {
    "@gmod/ucsc-hub": "^2.0.3",
    "@mui/icons-material": "^7.3.7"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@fal-works/esbuild-plugin-global-externals": "^2.1.2",
    "@jbrowse/core": "^4.1.3",
    "@jbrowse/mobx-state-tree": "^5.0.0",
    "@mui/material": "^7.3.7",
    "@mui/system": "^7.3.7",
    "@mui/x-data-grid": "^8.26.0",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "mobx": "^6.13.6",
    "mobx-react": "^9.1.0",
    "mobx-state-tree": "5.0.0",
    "prettier": "^3.8.1",
    "pretty-bytes": "^7.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.1",
    "tss-react": "^4.9.15",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1"
  }
}
