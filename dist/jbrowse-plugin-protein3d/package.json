{
  "version": "0.4.4",
  "name": "jbrowse-plugin-protein3d",
  "repository": {
    "type": "git",
    "url": "https://github.com/GMOD/jbrowse-plugin-protein3d.git"
  },
  "keywords": [
    "jbrowse",
    "jbrowse2"
  ],
  "main": "dist/index.js",
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@jbrowse/app-core": "^4.3.0",
    "@jbrowse/plugin-linear-genome-view": "^4.3.0",
    "@mui/icons-material": "^7.3.11",
    "clustal-js": "^2.0.15",
    "g2p_mapper": "^2.1.5",
    "molstar": "^5.9.0",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@eslint/js": "^10.0.1",
    "@fal-works/esbuild-plugin-global-externals": "^2.1.2",
    "@jbrowse/core": "^4.3.0",
    "@jbrowse/mobx-state-tree": "^5.8.7",
    "@mui/material": "^7.3.11",
    "@mui/system": "^7.3.11",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "fp-ts": "^2.16.11",
    "jsdom": "^29.1.1",
    "mobx": "^6.15.3",
    "mobx-react": "^9.2.1",
    "prettier": "^3.8.3",
    "pretty-bytes": "^7.1.0",
    "puppeteer": "^24.43.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.4",
    "rxjs": "^7.8.2",
    "serve": "^14.2.6",
    "tss-react": "^4.9.21",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  },
  "author": "Colin <colin.diesh@gmail.com>",
  "license": "MIT",
  "scripts": {
    "test": "vitest",
    "test:watch": "vitest",
    "test:all": "node scripts/test-versions.mjs setup && node scripts/test-versions.mjs run",
    "test:setup": "node scripts/test-versions.mjs setup",
    "test:setup:version": "node scripts/test-versions.mjs setup",
    "test:versions": "node scripts/test-versions.mjs run",
    "test:version": "node scripts/test-versions.mjs run",
    "clean": "rimraf dist",
    "fetch-molstar-css": "node scripts/fetch-molstar-css.mjs",
    "format": "pnpm prettier --write .",
    "prebuild": "pnpm clean",
    "start": "pnpm fetch-molstar-css && node esbuild.mjs --watch",
    "build": "tsc && NODE_ENV=production node esbuild.mjs && cp distconfig.json dist/config.json",
    "build:bundle": "NODE_ENV=production node esbuild.mjs",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0",
    "pretest": "test -d .test-jbrowse-nightly || jbrowse create .test-jbrowse-nightly --nightly",
    "preversion": "pnpm lint",
    "version": "node -e \"console.log('export const version = \\'' + require('./package.json').version + '\\'')\" > src/version.ts && git add src/version.ts",
    "postversion": "git push --follow-tags"
  }
}