{
  "version": "0.2.0",
  "name": "jbrowse-plugin-protein3d",
  "keywords": [
    "jbrowse",
    "jbrowse2"
  ],
  "main": "dist/index.js",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "node scripts/test-versions.mjs setup && node scripts/test-versions.mjs run",
    "test:setup": "node scripts/test-versions.mjs setup",
    "test:setup:version": "node scripts/test-versions.mjs setup",
    "test:versions": "node scripts/test-versions.mjs run",
    "test:version": "node scripts/test-versions.mjs run",
    "clean": "rimraf dist",
    "fetch-molstar-css": "node scripts/fetch-molstar-css.mjs",
    "format": "prettier --write .",
    "prebuild": "yarn clean && yarn fetch-molstar-css",
    "start": "yarn fetch-molstar-css && node esbuild.mjs --watch",
    "build": "tsc && NODE_ENV=production node esbuild.mjs && cp distconfig.json dist/config.json",
    "build:bundle": "NODE_ENV=production node esbuild.mjs",
    "lint": "eslint --report-unused-disable-directives --max-warnings 0",
    "pretest": "test -d .test-jbrowse-nightly || jbrowse create .test-jbrowse-nightly --nightly",
    "prepack": "yarn build",
    "prepublishOnly": "node -e \"console.log('export const version = \\'' + require('./package.json').version + '\\'')\" > src/version.ts && git add -A src && git diff --cached --quiet || git commit -m '[skip ci] Bump version.ts'",
    "preversion": "yarn lint",
    "postversion": "git push --follow-tags"
  },
  "dependencies": {
    "@jbrowse/app-core": "^4.1.13",
    "@jbrowse/plugin-linear-genome-view": "^4.1.13",
    "@mui/icons-material": "^7.3.8",
    "clustal-js": "^2.0.11",
    "g2p_mapper": "^2.0.0",
    "molstar": "^5.7.0",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@emotion/react": "^11.13.0",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@fal-works/esbuild-plugin-global-externals": "^2.1.2",
    "@jbrowse/core": "^4.1.13",
    "@jbrowse/mobx-state-tree": "^5.6.0",
    "@mui/material": "^7.3.8",
    "@mui/system": "^7.3.8",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "esbuild": "^0.27.3",
    "eslint": "^9",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.20.3",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fp-ts": "^2.16.11",
    "mobx": "^6.0.0",
    "mobx-react": "^9.0.1",
    "prettier": "^3.8.1",
    "pretty-bytes": "^7.0.0",
    "puppeteer": "^24.37.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "rxjs": "^7.0.0",
    "serve": "^14.2.5",
    "tss-react": "^4.9.4",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "author": "Colin <colin.diesh@gmail.com>",
  "license": "MIT"
}
